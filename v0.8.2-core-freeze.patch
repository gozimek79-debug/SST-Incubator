 def _hash_stimulus(value: float, buckets: int = 100) -> int:
+    """Hashuj wartość bodźca do dyskretnego bucketa.
+
+    Args:
+        value: Wartość bodźca.
+        buckets: Liczba bucketów.
+
+    Returns:
